(kicad_pcb
  (version 20221018)
  (generator "cortipod_electrode_designer")
  (general
    (thickness 0.8)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
    (50 "User.1" user)
    (51 "User.2" user)
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions yes)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (excludeedgelayer yes)
      (linewidth 0.100000)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  (net 0 "")
  (net 1 "WE_MIP")
  (net 2 "WE_NIP")
  (net 3 "CE")
  (net 4 "RE")

  (gr_line (start 137.5 94) (end 159.5 94) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 159.5 94) (end 159.5 116) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 159.5 116) (end 139 116) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 139 116) (end 137.5 114.5) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 137.5 114.5) (end 137.5 94) (layer "Edge.Cuts") (width 0.05))

  (gr_line (start 137.5 112) (end 159.5 112) (layer "Dwgs.User") (width 0.15))

  (gr_text "V-SCORE (snap off tab for pod)"
    (at 148.5 113) (layer "Dwgs.User")
    (effects (font (size 0.4 0.4) (thickness 0.08)))
  )

  (gr_text "CortiPod Dual Electrode v4.0 (22x22mm)"
    (at 148.5 92.5) (layer "Cmts.User")
    (effects (font (size 0.6 0.6) (thickness 0.08)))
  )

  (footprint "CortiPod:DualElectrodeCell" (layer "F.Cu")
    (tstamp "a1b2c3d4-0001-0001-0001-000000000001")
    (at 148.5 103)

    (property "Reference" "E1"
      (at 0 -8.5) (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )

    (fp_text user "MIP" (at -5 3) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)))
    )
    (fp_text user "NIP" (at 5 3) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)))
    )
    (fp_text user "CE" (at 0 -6.5) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)))
    )
    (fp_text user "RE" (at 0 8) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)))
    )

    (fp_text user "MIP" (at -4 -3) (layer "B.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)) (justify mirror))
    )
    (fp_text user "NIP" (at 4 -3) (layer "B.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)) (justify mirror))
    )
    (fp_text user "CE" (at -4 3) (layer "B.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)) (justify mirror))
    )
    (fp_text user "RE" (at 4 3) (layer "B.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08)) (justify mirror))
    )

    (pad "1" smd circle
      (at -5 0)
      (size 8 8)
      (layers "F.Cu" "F.Mask")
      (net 1 "WE_MIP")
    )

    (pad "2" smd circle
      (at 5 0)
      (size 8 8)
      (layers "F.Cu" "F.Mask")
      (net 2 "WE_NIP")
    )

    (pad "3T" smd roundrect
      (at 0 -5.5)
      (size 20 2)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.2)
      (net 3 "CE")
    )

    (pad "3B" smd roundrect
      (at 0 5.5)
      (size 20 2)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.2)
      (net 3 "CE")
    )

    (pad "3L" smd roundrect
      (at -9.75 0)
      (size 1 8)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.2)
      (net 3 "CE")
    )

    (pad "3R" smd roundrect
      (at 9.75 0)
      (size 1 8)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.2)
      (net 3 "CE")
    )

    (pad "4" smd circle
      (at 0 7.5)
      (size 2 2)
      (layers "F.Cu" "F.Mask" "F.Paste")
      (net 4 "RE")
    )

    (pad "5" smd circle
      (at -4 -2)
      (size 1.8 1.8)
      (layers "B.Cu" "B.Mask")
      (net 1 "WE_MIP")
    )

    (pad "6" smd circle
      (at 4 -2)
      (size 1.8 1.8)
      (layers "B.Cu" "B.Mask")
      (net 2 "WE_NIP")
    )

    (pad "7" smd circle
      (at -4 4)
      (size 1.8 1.8)
      (layers "B.Cu" "B.Mask")
      (net 3 "CE")
    )

    (pad "8" smd circle
      (at 4 4)
      (size 1.8 1.8)
      (layers "B.Cu" "B.Mask")
      (net 4 "RE")
    )

    (fp_circle (center -5 0) (end -1 0) (layer "User.1") (width 0) (fill solid))
    (fp_circle (center 5 0) (end 9 0) (layer "User.1") (width 0) (fill solid))

    (fp_circle (center -5 0) (end -1 0) (layer "User.2") (width 0) (fill solid))
    (fp_circle (center 5 0) (end 9 0) (layer "User.2") (width 0) (fill solid))
    (fp_rect (start -10 -6.5) (end 10 -4.5) (layer "User.2") (width 0) (fill solid))
    (fp_rect (start -10 4.5) (end 10 6.5) (layer "User.2") (width 0) (fill solid))
    (fp_rect (start -10.25 -4) (end -9.25 4) (layer "User.2") (width 0) (fill solid))
    (fp_rect (start 9.25 -4) (end 10.25 4) (layer "User.2") (width 0) (fill solid))

    (fp_rect (start -10.5 -7) (end 10.5 9) (layer "F.CrtYd") (width 0.05))

    (fp_circle (center -5 0) (end -1 0) (layer "F.Fab") (width 0.1))
    (fp_circle (center 5 0) (end 9 0) (layer "F.Fab") (width 0.1))
    (fp_rect (start -10 -6.5) (end 10 -4.5) (layer "F.Fab") (width 0.1))
    (fp_rect (start -10 4.5) (end 10 6.5) (layer "F.Fab") (width 0.1))
    (fp_circle (center 0 7.5) (end 1 7.5) (layer "F.Fab") (width 0.1))
  )

  (footprint "CortiPod:TestPoints" (layer "F.Cu")
    (tstamp "b1b2c3d4-0004-0004-0004-000000000004")
    (at 148.5 114)

    (fp_text user "MIP" (at -7.5 -1) (layer "F.SilkS")
      (effects (font (size 0.35 0.35) (thickness 0.07)))
    )
    (fp_text user "NIP" (at -2.5 -1) (layer "F.SilkS")
      (effects (font (size 0.35 0.35) (thickness 0.07)))
    )
    (fp_text user "CE" (at 2.5 -1) (layer "F.SilkS")
      (effects (font (size 0.35 0.35) (thickness 0.07)))
    )
    (fp_text user "RE" (at 7.5 -1) (layer "F.SilkS")
      (effects (font (size 0.35 0.35) (thickness 0.07)))
    )

    (pad "TP1" smd roundrect
      (at -7.5 0)
      (size 3 1.5)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.25)
      (net 1 "WE_MIP")
    )

    (pad "TP2" smd roundrect
      (at -2.5 0)
      (size 3 1.5)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.25)
      (net 2 "WE_NIP")
    )

    (pad "TP3" smd roundrect
      (at 2.5 0)
      (size 3 1.5)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.25)
      (net 3 "CE")
    )

    (pad "TP4" smd roundrect
      (at 7.5 0)
      (size 3 1.5)
      (layers "F.Cu" "F.Mask")
      (roundrect_rratio 0.25)
      (net 4 "RE")
    )
  )

  (via (at 147 103) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 150 103) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 144.5 107) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 152.5 107) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 149.3 110.5) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 4))

  (segment (start 147 103) (end 144.5 101) (width 0.5) (layer "B.Cu") (net 1))
  (segment (start 150 103) (end 152.5 101) (width 0.5) (layer "B.Cu") (net 2))
  (segment (start 149.3 110.5) (end 152.5 107) (width 0.5) (layer "B.Cu") (net 4))

  (segment (start 143.5 103) (end 141 114) (width 0.5) (layer "F.Cu") (net 1))
  (segment (start 153.5 103) (end 146 114) (width 0.5) (layer "F.Cu") (net 2))
  (segment (start 148.5 108.5) (end 151 114) (width 0.5) (layer "F.Cu") (net 3))
  (segment (start 148.5 110.5) (end 156 114) (width 0.5) (layer "F.Cu") (net 4))

  (segment (start 138.5 94) (end 138.5 112) (width 0.8) (layer "F.Cu") (net 1))
  (segment (start 138.5 103) (end 143.5 103) (width 0.5) (layer "F.Cu") (net 1))

  (segment (start 158.5 94) (end 158.5 112) (width 0.8) (layer "F.Cu") (net 2))
  (segment (start 158.5 103) (end 153.5 103) (width 0.5) (layer "F.Cu") (net 2))

  (footprint "CortiPod:BusPad_MIP" (layer "F.Cu")
    (tstamp "a1b2c3d4-0002-0002-0002-000000000002")
    (at 138.5 95)
    (pad "MIP_BUS" smd rect
      (at 0 0)
      (size 1.5 1.5)
      (layers "F.Cu" "F.Mask")
      (net 1 "WE_MIP")
    )
  )

  (footprint "CortiPod:BusPad_NIP" (layer "F.Cu")
    (tstamp "a1b2c3d4-0003-0003-0003-000000000003")
    (at 158.5 95)
    (pad "NIP_BUS" smd rect
      (at 0 0)
      (size 1.5 1.5)
      (layers "F.Cu" "F.Mask")
      (net 2 "WE_NIP")
    )
  )
)
